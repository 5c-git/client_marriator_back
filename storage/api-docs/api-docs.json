                            "application/json": {
                                "schema": {},
                                "examples": {
                                    "success refresh token": {
                                        "summary": "Успешное востановление",
                                        "value": {
                                            "status": "success",
                                            "result": {
                                                "token": {
                                                    "token_type": "Bearer",
